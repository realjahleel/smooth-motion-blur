{
	"schemaVersion": 1,
	"id": "motionblur",
	"version": "${version}",
	"name": "Smooth Motion Blur",
	"description": "Velocity-based motion blur with directional streaks, like Natural Motion Blur. Blur technique adapted from Natural Motion Blur by ItsPasi (LGPL-3.0). Adjustable in-game via /motionblur 0-100, VulkanMod compatible.",
	"authors": [
		"Jahleel"
	],
	"contributors": [
		"ItsPasi (Natural Motion Blur, blur technique)"
	],
	"contact": {},
	"license": "LGPL-3.0-only",
	"icon": "assets/motionblur/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.jahleel.motionblur.client.MotionBlurClient"
		],
		"modmenu": [
			"com.jahleel.motionblur.client.MotionBlurModMenu"
		]
	},
	"mixins": [
		{
			"config": "motionblur.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.0",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"custom": {}
}
